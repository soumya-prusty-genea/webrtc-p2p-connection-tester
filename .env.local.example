# Copy to `.env.local` (git-ignored) and fill in real secrets.
# docker-compose loads this file automatically (required: false).

# Shared secret used to sign/verify the signaling JWT. Must match the server.
JWT_SECRET=replace-with-shared-secret

# Optional: TURN long-term credentials used by the network probe to perform a
# full authenticated Allocate (proves a relay candidate can be allocated).
# WEBRTC_TURN_USERNAME=turnuser
# WEBRTC_TURN_PASSWORD=turnpass
