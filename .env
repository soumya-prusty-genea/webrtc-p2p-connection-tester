# AWS / ECR (optional — only needed if pushing to ECR)
AWS_ACCOUNT_ID=123456    
AWS_REGION=us-east-1               

# Runtime environmentAPP_ENV=default

# Signaling server (use host.docker.internal when gateway runs in Docker on Mac)
SIGNALING_SERVER_URL=http://3.92.130.253:3000/gateway
# SFU identity
SFU_ID=GW-12346
TIMESTAMP_SOURCE=system
USE_TEST_STREAM=true
# Optional: log total stream egress (bytes) at this interval (seconds)
TOTAL_STREAM_EGRESS_LOG_INTERVAL_SECS=30

# Camera/runtime limits
VIEWER_LIMIT_MODE=gateway
MAX_VIEWERS_PER_CAMERA=10
MAX_VIEWERS_PER_GATEWAY=10
DEFAULT_VIDEO_CODEC=H264

# Persistent state
STATE_FILE_PATH=./sfu_state.json

RECOVERY_WATCHDOG_INTERVAL_SECS=3
RECOVERY_WATCHDOG_STALLED_WINDOWS=2
RECOVERY_MIN_INPUT_FPS=1.0
RECOVERY_RESTART_COOLDOWN_SECS=10

# Test-only fault injection: force output metrics/counters to zero for a window.
# Useful to validate watchdog-triggered auto-restart.
RECOVERY_TEST_FORCE_ZERO_OUTPUT_ENABLED=false
RECOVERY_TEST_FORCE_ZERO_OUTPUT_CYCLE_SECS=30
RECOVERY_TEST_FORCE_ZERO_OUTPUT_ACTIVE_SECS=15

# JWT Authentication (Header-Based)
# JWT_AUTH_ENABLED=false  ← uncomment to disable auth without removing credentials
JWT_AUTH_ENABLED=true
GATEWAY_UUID=GW-12346
CUSTOMER_UUID=CUST-98765
# SECURITY: the JWT secret is NOT stored in this committed file.
# Put it in `.env.local` (git-ignored), e.g.:
JWT_SECRET=ee4f45c5f24e4546b5aafea1b82f1ded8f9f9c4e43a5c20f1e05e63954d331cf
# or export JWT_SECRET in the environment / inject it from your secrets manager.
# JWT_SECRET must match the secret the signaling server uses to verify tokens.
JWT_EXPIRY_SECS=86400
# Logging
RUST_LOG=info

# Build toolchain overrides (for local cargo builds with gg-sdk C sources)
CC=gcc
CXX=g++
CC_aarch64_unknown_linux_gnu=gcc
CXX_aarch64_unknown_linux_gnu=g++
